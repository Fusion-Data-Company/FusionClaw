# ─── Database (Neon PostgreSQL) ───────────────────────────────
# Get a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require

# ─── AI Services ─────────────────────────────────────────────
# OpenRouter — AI text generation, chat, humanizer
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# fal.ai — Image generation (Flux, Nano Banana)
# Get key: https://fal.ai/dashboard/keys
FAL_KEY=

# ─── Authentication ──────────────────────────────────────────
# FusionClaw is self-hosted. There is no third-party auth provider.
#
# Localhost (npm run dev): no auth required. You're trusted.
# Deployed (Vercel, your own server): set OWNER_PASSWORD below.
#   The /login page accepts that password and sets a session cookie.
#   Anyone connecting to a non-localhost host is required to authenticate.
#
# Leave OWNER_PASSWORD blank for localhost-only / dev work.
OWNER_PASSWORD=

# Optional — owner identity shown in the UI. Defaults to "Owner" / "owner@localhost".
OWNER_EMAIL=
OWNER_NAME=

# Optional — secret used to sign session JWTs.
# If unset, falls back to MCP_API_KEY. Set this explicitly in production for safety.
SESSION_SECRET=

# ─── MCP Server (AI Agent Access) ───────────────────────────
# Auto-generated by `npm run onboard`, or set manually
# Format: fusionclaw_sk_live_<random>
# This key grants AI agents (Claude, OpenClaw) access to all API routes.
# Keep it secret — it bypasses session auth on API routes.
MCP_API_KEY=

# ─── File Storage (Vercel Blob) — Optional ───────────────────
# Get from Vercel project settings > Storage. Only needed for Studio image uploads.
BLOB_READ_WRITE_TOKEN=

# ─── Encryption (API Key Vault) — Optional ───────────────────
# 64-char hex string for AES-256-GCM encryption of user-supplied API keys
# stored in the Settings module. Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ─── Google Workspace (Optional) ─────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Set redirect URI to: {APP_URL}/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
