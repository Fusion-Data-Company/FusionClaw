# ─── Database (Neon PostgreSQL) ───────────────────────────────
# Get a free database at https://neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ─── AI Services ─────────────────────────────────────────────
# OpenRouter — AI text generation, chat, humanizer
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# fal.ai — Image generation (Flux, Nano Banana)
# Get key: https://fal.ai/dashboard/keys
FAL_KEY=

# ─── Authentication ──────────────────────────────────────────
# Single gateway password for admin login
GATEWAY_PASSWORD=change-me-to-something-secure

# Admin identity (shown in UI)
ADMIN_EMAIL=you@example.com
ADMIN_NAME=Your Name

# ─── MCP Server (AI Agent Access) ───────────────────────────
# Auto-generated by `npm run onboard`, or set manually
# Format: fusionclaw_sk_live_<random>
MCP_API_KEY=

# ─── File Storage (Vercel Blob) ──────────────────────────────
# Get from Vercel project settings > Storage
BLOB_READ_WRITE_TOKEN=

# ─── Google Workspace (Optional) ─────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Set redirect URI to: {APP_URL}/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
