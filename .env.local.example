# Neon PostgreSQL (use -pooler hostname for serverless)
DATABASE_URL=postgresql://...@...-pooler.neon.tech/fusionclaw?sslmode=require

# OpenRouter — required for skills, forge, council, reflection loop, chat, humanizer
OPENROUTER_API_KEY=sk-or-v1-...

# OpenAI — optional, unlocks /voice (Realtime API) and voice-note transcription (Whisper)
OPENAI_API_KEY=sk-...

# fal.ai (Image Generation)
FAL_KEY=...

# Auth — leave OWNER_PASSWORD blank for localhost-only.
# Set it before deploying anywhere with a public URL.
OWNER_PASSWORD=
OWNER_EMAIL=
OWNER_NAME=

# Session signing secret (generated by `npm run onboard`)
SESSION_SECRET=

# MCP Server (Agent Access) — generated by `npm run onboard`
MCP_API_KEY=fusionclaw_sk_live_...

# Encryption key for user-supplied API keys stored in Settings
ENCRYPTION_KEY=

# Vercel Blob (File Storage) — optional, only for Studio uploads
BLOB_READ_WRITE_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
